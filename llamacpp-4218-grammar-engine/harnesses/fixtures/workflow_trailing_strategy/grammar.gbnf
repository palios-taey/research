char ::= [^"\\\x7F\x00-\x1F] | [\\] (["\\bfnrt] | "u" [0-9a-fA-F]{4})
ref-defs-ParallelGroup ::= "{" space ref-defs-ParallelGroup-title-kv "," space ref-defs-ParallelGroup-children-kv "," space ref-defs-ParallelGroup-strategy-kv "}" space
ref-defs-ParallelGroup-children ::= "[" space ref-defs-ParallelGroup-children-item? "]" space
ref-defs-ParallelGroup-children-item ::= ref-defs-ParallelGroup-children-item-0 | ref-defs-ParallelGroup-children-item-1
ref-defs-ParallelGroup-children-item-0 ::= ref-defs-SequentialGroup
ref-defs-ParallelGroup-children-item-1 ::= ref-defs-ParallelGroup
ref-defs-ParallelGroup-children-kv ::= "\"children\"" space ":" space ref-defs-ParallelGroup-children
ref-defs-ParallelGroup-strategy ::= "\"parallel\"" space
ref-defs-ParallelGroup-strategy-kv ::= "\"strategy\"" space ":" space ref-defs-ParallelGroup-strategy
ref-defs-ParallelGroup-title-kv ::= "\"title\"" space ":" space string
ref-defs-SequentialGroup ::= "{" space ref-defs-SequentialGroup-title-kv "," space ref-defs-SequentialGroup-children-kv "," space ref-defs-SequentialGroup-strategy-kv "}" space
ref-defs-SequentialGroup-children ::= "[" space ref-defs-SequentialGroup-children-item? "]" space
ref-defs-SequentialGroup-children-item ::= ref-defs-SequentialGroup-children-item-0 | ref-defs-SequentialGroup-children-item-1
ref-defs-SequentialGroup-children-item-0 ::= ref-defs-SequentialGroup
ref-defs-SequentialGroup-children-item-1 ::= ref-defs-ParallelGroup
ref-defs-SequentialGroup-children-kv ::= "\"children\"" space ":" space ref-defs-SequentialGroup-children
ref-defs-SequentialGroup-strategy ::= "\"sequential\"" space
ref-defs-SequentialGroup-strategy-kv ::= "\"strategy\"" space ":" space ref-defs-SequentialGroup-strategy
ref-defs-SequentialGroup-title-kv ::= "\"title\"" space ":" space string
root ::= "{" space root-kv "}" space
root- ::= root-0 | root-1
root-0 ::= ref-defs-SequentialGroup
root-1 ::= ref-defs-ParallelGroup
root-kv ::= "\"root\"" space ":" space root-
space ::= | " " | "\n"{1,2} [ \t]{0,20}
string ::= "\"" char* "\"" space
